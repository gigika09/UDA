<?xml version="1.0" encoding="UTF-8"?>
<!--
    project.xml — Descrittore del progetto NetBeans
    ════════════════════════════════════════════════════════════════════
    Questo file dice a NetBeans il TIPO di progetto (org.netbeans.modules.java.j2seproject),
    il nome visualizzato nel Project Explorer e i riferimenti alle
    cartelle sorgenti e di configurazione Ant.

    NetBeans lo legge all'apertura del progetto per costruire
    l'albero dei package nel pannello "Projects".
    ════════════════════════════════════════════════════════════════════
-->
<project xmlns="http://www.netbeans.org/ns/project/1">

    <!-- Tipo di progetto: applicazione Java SE standard -->
    <type>org.netbeans.modules.java.j2seproject</type>

    <configuration>
        <data xmlns="http://www.netbeans.org/ns/j2se-project/3">

            <!-- Nome visualizzato nel Project Explorer di NetBeans -->
            <name>GestioneRimborsi</name>

            <!-- Cartelle dei sorgenti Java -->
            <source-roots>
                <root id="src.dir" name="Source Packages"/>
            </source-roots>

            <!-- Cartelle dei test (vuote, ma richieste da NetBeans) -->
            <test-roots>
                <root id="test.src.dir" name="Test Packages"/>
            </test-roots>

        </data>
    </configuration>
</project>
